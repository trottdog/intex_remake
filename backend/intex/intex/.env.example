# ASP.NET runtime
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080

# PostgreSQL (Supabase pooler)
# Preferred key used by the backend:
ConnectionStrings__PostgreSql=Host=aws-1-us-east-2.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.<project-ref>;Password=<db-password>;SSL Mode=Require;Trust Server Certificate=true;Max Auto Prepare=0

# Optional fallback key (only used if ConnectionStrings__PostgreSql is not set)
DATABASE_URL=Host=aws-1-us-east-2.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.<project-ref>;Password=<db-password>;SSL Mode=Require;Trust Server Certificate=true;Max Auto Prepare=0

# JWT
JWT_SECRET=<at-least-32-char-random-secret>
Jwt__ExpiryHours=8

# CORS (Vercel frontend)
# You can set either CORS_ALLOWED_ORIGINS (comma-separated) or VERCEL_FRONTEND_ORIGIN.
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# VERCEL_FRONTEND_ORIGIN=https://your-frontend.vercel.app
# FRONTEND_ORIGIN=https://your-frontend.vercel.app

# Azure hosting flags
AzureHosting__UseForwardedHeaders=true
AzureHosting__UseHsts=true

# Optional telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=<application-insights-connection-string>

# Optional Supabase project URL (for future SDK use)
Supabase__Url=https://<project-ref>.supabase.co
