{
  "ConnectionStrings": {
    "PostgreSql": "Host=aws-1-us-east-2.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.<project-ref>;Password=<db-password>;SSL Mode=Require;Trust Server Certificate=true;Max Auto Prepare=0"
  },
  "AzureHosting": {
    "UseForwardedHeaders": true,
    "UseHsts": true
  },
