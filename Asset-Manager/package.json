{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');for(const f of['package-lock.json','yarn.lock']){try{fs.unlinkSync(f)}catch{}}if(!(process.env.npm_config_user_agent||'').includes('pnpm')){console.error('Use pnpm instead');process.exit(1)}\"",
    "dev": "pnpm --filter @workspace/beacon dev",
    "dev:frontend": "pnpm --filter @workspace/beacon dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:frontend": "pnpm --filter @workspace/beacon build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "tsx": "catalog:"
  }
}
