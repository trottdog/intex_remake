# Copy to ml/.env or set these variables in your shell / GitHub Actions secrets.

# Set to true when you want the ML loaders to read raw source tables from Supabase/Postgres
# instead of local CSV exports.
ML_USE_SUPABASE=true

# Recommended for the nightly retrain workflow:
# use the direct Supabase Postgres connection on port 5432 when possible.
# Example format:
# SUPABASE_DB_CONNECTION_STRING=Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
SUPABASE_DB_CONNECTION_STRING=
